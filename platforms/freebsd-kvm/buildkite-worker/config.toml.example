# We define groups of workers by name, each with their own configuration.
# Cluster agents can only listen to a single queue, so a machine that should
# serve both the `build` and `test` queues defines one group per queue.
[scheduler]
logdir="@scratch/freebsd-kvm-logs"

[freebsd13-builder]
backend="kvm"
guest="freebsd"
queues="build"
num_agents=1
num_cpus=8

# `cachedir` holds the per-job cache disks (qcow2 overlays, partitioned by
# pipeline and trust); the throwaway OS-disk overlays and VM XML live under
# `tempdir`.  Both default to a Scratch.jl scratchspace / the system temp dir;
# point them at disks that can handle the VMs' write load.  On AppArmor hosts,
# grant libvirt-qemu access to non-default locations by adding `<cachedir>/** rk,`
# and `<tempdir>/** rk,` to /etc/apparmor.d/local/abstractions/libvirt-qemu.
#cachedir="/data/agent_build"
#tempdir="/data/agent_tmp"

[freebsd13-builder.tags]
# Manually override this to say `freebsd`, even though we're on a linux host
os="freebsd"

[freebsd13-tester]
backend="kvm"
guest="freebsd"
queues="test"
num_agents=2
num_cpus=8

[freebsd13-tester.tags]
os="freebsd"
